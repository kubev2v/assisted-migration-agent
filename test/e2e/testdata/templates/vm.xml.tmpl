<ObjectContent>
  <obj type="VirtualMachine">vm-{{.VMID}}</obj>
  <propSet>
    <name>value</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfCustomFieldValue"></val>
  </propSet>
  <propSet>
    <name>availableField</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfCustomFieldDef"></val>
  </propSet>
  <propSet>
    <name>parent</name>
    <val type="Folder" xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ManagedObjectReference">{{.ParentFolder}}</val>
  </propSet>
  <propSet>
    <name>customValue</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfCustomFieldValue"></val>
  </propSet>
  <propSet>
    <name>overallStatus</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ManagedEntityStatus">green</val>
  </propSet>
  <propSet>
    <name>configStatus</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ManagedEntityStatus">green</val>
  </propSet>
  <propSet>
    <name>configIssue</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfEvent"></val>
  </propSet>
  <propSet>
    <name>effectiveRole</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfInt">
      <int>-1</int>
    </val>
  </propSet>
  <propSet>
    <name>permission</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfPermission"></val>
  </propSet>
  <propSet>
    <name>name</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="xsd:string">{{.Name}}</val>
  </propSet>
  <propSet>
    <name>disabledMethod</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfString"></val>
  </propSet>
  <propSet>
    <name>recentTask</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfManagedObjectReference">
      <ManagedObjectReference type="Task">task-{{.PowerOnTask}}</ManagedObjectReference>
    </val>
  </propSet>
  <propSet>
    <name>declaredAlarmState</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfAlarmState"></val>
  </propSet>
  <propSet>
    <name>triggeredAlarmState</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfAlarmState"></val>
  </propSet>
  <propSet>
    <name>tag</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfTag"></val>
  </propSet>
  <propSet>
    <name>capability</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="VirtualMachineCapability">
      <snapshotOperationsSupported>false</snapshotOperationsSupported>
      <multipleSnapshotsSupported>false</multipleSnapshotsSupported>
      <snapshotConfigSupported>false</snapshotConfigSupported>
      <poweredOffSnapshotsSupported>false</poweredOffSnapshotsSupported>
      <memorySnapshotsSupported>false</memorySnapshotsSupported>
      <revertToSnapshotSupported>false</revertToSnapshotSupported>
      <quiescedSnapshotsSupported>false</quiescedSnapshotsSupported>
      <disableSnapshotsSupported>false</disableSnapshotsSupported>
      <lockSnapshotsSupported>false</lockSnapshotsSupported>
      <consolePreferencesSupported>false</consolePreferencesSupported>
      <cpuFeatureMaskSupported>false</cpuFeatureMaskSupported>
      <s1AcpiManagementSupported>false</s1AcpiManagementSupported>
      <settingScreenResolutionSupported>false</settingScreenResolutionSupported>
      <toolsAutoUpdateSupported>false</toolsAutoUpdateSupported>
      <vmNpivWwnSupported>false</vmNpivWwnSupported>
      <npivWwnOnNonRdmVmSupported>false</npivWwnOnNonRdmVmSupported>
      <vmNpivWwnDisableSupported>false</vmNpivWwnDisableSupported>
      <vmNpivWwnUpdateSupported>false</vmNpivWwnUpdateSupported>
      <swapPlacementSupported>false</swapPlacementSupported>
      <toolsSyncTimeSupported>false</toolsSyncTimeSupported>
      <virtualMmuUsageSupported>false</virtualMmuUsageSupported>
      <diskSharesSupported>false</diskSharesSupported>
      <bootOptionsSupported>false</bootOptionsSupported>
      <bootRetryOptionsSupported>false</bootRetryOptionsSupported>
      <settingVideoRamSizeSupported>false</settingVideoRamSizeSupported>
      <settingDisplayTopologySupported>false</settingDisplayTopologySupported>
      <recordReplaySupported>false</recordReplaySupported>
      <changeTrackingSupported>true</changeTrackingSupported>
      <multipleCoresPerSocketSupported>false</multipleCoresPerSocketSupported>
      <hostBasedReplicationSupported>false</hostBasedReplicationSupported>
      <guestAutoLockSupported>false</guestAutoLockSupported>
      <memoryReservationLockSupported>false</memoryReservationLockSupported>
      <featureRequirementSupported>false</featureRequirementSupported>
      <poweredOnMonitorTypeChangeSupported>false</poweredOnMonitorTypeChangeSupported>
      <seSparseDiskSupported>false</seSparseDiskSupported>
      <nestedHVSupported>false</nestedHVSupported>
      <vPMCSupported>false</vPMCSupported>
    </val>
  </propSet>
  <propSet>
    <name>config</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="VirtualMachineConfigInfo">
      <changeVersion>{{.Timestamp}}</changeVersion>
      <modified>{{.Timestamp}}</modified>
      <name>{{.Name}}</name>
      <guestFullName>otherGuest</guestFullName>
      <version>vmx-13</version>
      <uuid>{{.UUID}}</uuid>
      <createDate>{{.Timestamp}}</createDate>
      <instanceUuid>{{.InstanceUUID}}</instanceUuid>
      <template>false</template>
      <guestId>otherGuest</guestId>
      <alternateGuestName></alternateGuestName>
      <files>
        <vmPathName>[LocalDS_0] {{.Name}}/{{.Name}}.vmx</vmPathName>
        <snapshotDirectory>[LocalDS_0] {{.Name}}</snapshotDirectory>
        <suspendDirectory>[LocalDS_0] {{.Name}}</suspendDirectory>
        <logDirectory>[LocalDS_0] {{.Name}}</logDirectory>
      </files>
      <tools></tools>
      <flags></flags>
      <defaultPowerOps></defaultPowerOps>
      <hardware>
        <numCPU>{{.NumCPU}}</numCPU>
        <numCoresPerSocket>1</numCoresPerSocket>
        <memoryMB>{{.MemoryMB}}</memoryMB>
        <device _XMLSchema-instance:type="VirtualIDEController">
          <key>200</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>IDE 0</label>
            <summary>IDE 0</summary>
          </deviceInfo>
          <busNumber>0</busNumber>
        </device>
        <device _XMLSchema-instance:type="VirtualIDEController">
          <key>201</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>IDE 1</label>
            <summary>IDE 1</summary>
          </deviceInfo>
          <busNumber>1</busNumber>
        </device>
        <device _XMLSchema-instance:type="VirtualPS2Controller">
          <key>300</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>PS2 controller 0</label>
            <summary>PS2 controller 0</summary>
          </deviceInfo>
          <busNumber>0</busNumber>
          <device>600</device>
          <device>700</device>
        </device>
        <device _XMLSchema-instance:type="VirtualPCIController">
          <key>100</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>PCI controller 0</label>
            <summary>PCI controller 0</summary>
          </deviceInfo>
          <busNumber>0</busNumber>
          <device>500</device>
          <device>12000</device>
        </device>
        <device _XMLSchema-instance:type="VirtualSIOController">
          <key>400</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>SIO controller 0</label>
            <summary>SIO controller 0</summary>
          </deviceInfo>
          <busNumber>0</busNumber>
        </device>
        <device _XMLSchema-instance:type="VirtualKeyboard">
          <key>600</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>Keyboard </label>
            <summary>Keyboard</summary>
          </deviceInfo>
          <controllerKey>300</controllerKey>
          <unitNumber>0</unitNumber>
        </device>
        <device _XMLSchema-instance:type="VirtualPointingDevice">
          <key>700</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>Pointing device</label>
            <summary>Pointing device; Device</summary>
          </deviceInfo>
          <backing _XMLSchema-instance:type="VirtualPointingDeviceDeviceBackingInfo">
            <deviceName></deviceName>
            <useAutoDetect>false</useAutoDetect>
            <hostPointingDevice>autodetect</hostPointingDevice>
          </backing>
          <controllerKey>300</controllerKey>
          <unitNumber>1</unitNumber>
        </device>
        <device _XMLSchema-instance:type="VirtualMachineVideoCard">
          <key>500</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>Video card </label>
            <summary>Video card</summary>
          </deviceInfo>
          <controllerKey>100</controllerKey>
          <unitNumber>0</unitNumber>
          <videoRamSizeInKB>4096</videoRamSizeInKB>
          <numDisplays>1</numDisplays>
          <useAutoDetect>false</useAutoDetect>
          <enable3DSupport>false</enable3DSupport>
          <use3dRenderer>automatic</use3dRenderer>
          <graphicsMemorySizeInKB>262144</graphicsMemorySizeInKB>
        </device>
        <device _XMLSchema-instance:type="VirtualMachineVMCIDevice">
          <key>12000</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>VMCI device</label>
            <summary>Device on the virtual machine PCI bus that provides support for the virtual machine communication interface</summary>
          </deviceInfo>
          <controllerKey>100</controllerKey>
          <unitNumber>17</unitNumber>
          <id>-1</id>
          <allowUnrestrictedCommunication>false</allowUnrestrictedCommunication>
          <filterEnable>true</filterEnable>
        </device>
        <device _XMLSchema-instance:type="ParaVirtualSCSIController">
          <key>202</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>pvscsi-202</label>
            <summary>pvscsi-202</summary>
          </deviceInfo>
          <busNumber>0</busNumber>
          <device>201</device>
          <sharedBus>noSharing</sharedBus>
          <scsiCtlrUnitNumber>7</scsiCtlrUnitNumber>
        </device>
        <device _XMLSchema-instance:type="VirtualCdrom">
          <key>203</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>cdrom-203</label>
            <summary>cdrom-203</summary>
          </deviceInfo>
          <backing _XMLSchema-instance:type="VirtualCdromAtapiBackingInfo">
            <deviceName>cdrom--201-{{.CdromDevName}}</deviceName>
            <useAutoDetect>false</useAutoDetect>
          </backing>
          <connectable>
            <startConnected>true</startConnected>
            <allowGuestControl>true</allowGuestControl>
            <connected>true</connected>
          </connectable>
          <controllerKey>202</controllerKey>
          <unitNumber>0</unitNumber>
        </device>
{{- range .Disks}}
        <device _XMLSchema-instance:type="VirtualDisk">
          <key>{{.Key}}</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>disk-202-{{.Index}}</label>
            <summary>{{.CapacityFmt}} KB</summary>
          </deviceInfo>
          <backing _XMLSchema-instance:type="VirtualDiskFlatVer2BackingInfo">
            <fileName>[LocalDS_0] {{.VMName}}/disk{{.DiskNum}}.vmdk</fileName>
            <datastore type="Datastore">datastore-39</datastore>
            <diskMode>persistent</diskMode>
            <split>false</split>
            <writeThrough>false</writeThrough>
            <thinProvisioned>true</thinProvisioned>
            <eagerlyScrub>false</eagerlyScrub>
            <uuid>{{.DiskUUID}}</uuid>
            <digestEnabled>false</digestEnabled>
          </backing>
          <controllerKey>202</controllerKey>
          <unitNumber>{{.UnitNumber}}</unitNumber>
          <capacityInKB>{{.CapacityKB}}</capacityInKB>
          <capacityInBytes>{{.CapacityB}}</capacityInBytes>
          <storageIOAllocation>
            <limit>-1</limit>
          </storageIOAllocation>
        </device>
{{- end}}
        <device _XMLSchema-instance:type="VirtualE1000">
          <key>4000</key>
          <deviceInfo _XMLSchema-instance:type="Description">
            <label>ethernet-0</label>
            <summary>DVSwitch: fea97929-4b2d-5972-b146-930c6d0b4014</summary>
          </deviceInfo>
          <backing _XMLSchema-instance:type="VirtualEthernetCardDistributedVirtualPortBackingInfo">
            <port>
              <switchUuid>fea97929-4b2d-5972-b146-930c6d0b4014</switchUuid>
              <portgroupKey>dvportgroup-12</portgroupKey>
            </port>
          </backing>
          <connectable>
            <startConnected>true</startConnected>
            <allowGuestControl>true</allowGuestControl>
            <connected>true</connected>
            <status>untried</status>
          </connectable>
          <slotInfo _XMLSchema-instance:type="VirtualDevicePciBusSlotInfo">
            <pciSlotNumber>32</pciSlotNumber>
          </slotInfo>
          <controllerKey>100</controllerKey>
          <unitNumber>7</unitNumber>
          <addressType>generated</addressType>
          <macAddress>{{.MACAddress}}</macAddress>
          <wakeOnLanEnabled>true</wakeOnLanEnabled>
          <resourceAllocation>
            <reservation>0</reservation>
            <share>
              <shares>50</shares>
              <level>normal</level>
            </share>
            <limit>-1</limit>
          </resourceAllocation>
        </device>
      </hardware>
      <cpuAllocation>
        <reservation>0</reservation>
        <expandableReservation>true</expandableReservation>
        <limit>-1</limit>
        <shares>
          <shares>0</shares>
          <level>normal</level>
        </shares>
      </cpuAllocation>
      <memoryAllocation>
        <reservation>0</reservation>
        <expandableReservation>true</expandableReservation>
        <limit>-1</limit>
        <shares>
          <shares>0</shares>
          <level>normal</level>
        </shares>
      </memoryAllocation>
      <latencySensitivity>
        <level>normal</level>
      </latencySensitivity>
      <extraConfig _XMLSchema-instance:type="OptionValue">
        <key>govcsim</key>
        <value _XMLSchema-instance:type="xsd:string">TRUE</value>
      </extraConfig>
      <bootOptions></bootOptions>
      <firmware>bios</firmware>
    </val>
  </propSet>
  <propSet>
    <name>layout</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="VirtualMachineFileLayout">
      <configFile>{{.Name}}.nvram</configFile>
      <logFile>vmware.log</logFile>
{{- range .Disks}}
      <disk>
        <key>{{.Key}}</key>
        <diskFile>[LocalDS_0] {{.VMName}}/disk{{.DiskNum}}.vmdk</diskFile>
      </disk>
{{- end}}
    </val>
  </propSet>
  <propSet>
    <name>layoutEx</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="VirtualMachineFileLayoutEx">
      <file>
        <key>0</key>
        <name>[LocalDS_0] {{.Name}}.nvram</name>
        <type>nvram</type>
        <size>0</size>
        <accessible>true</accessible>
      </file>
      <file>
        <key>1</key>
        <name>[LocalDS_0] {{.Name}}.vmx</name>
        <type>config</type>
        <size>0</size>
        <accessible>true</accessible>
      </file>
      <file>
        <key>2</key>
        <name>[LocalDS_0] disk1-flat.vmdk</name>
        <type>diskExtent</type>
        <size>0</size>
        <accessible>true</accessible>
      </file>
      <file>
        <key>3</key>
        <name>[LocalDS_0] disk1.vmdk</name>
        <type>diskDescriptor</type>
        <size>0</size>
        <accessible>true</accessible>
      </file>
      <file>
        <key>4</key>
        <name>[LocalDS_0] vmware.log</name>
        <type>log</type>
        <size>32</size>
        <uniqueSize>32</uniqueSize>
        <accessible>true</accessible>
      </file>
{{- range .Disks}}
      <file>
        <key>{{.FileKeyBase}}</key>
        <name>[LocalDS_0] {{.VMName}}/disk{{.DiskNum}}-flat.vmdk</name>
        <type>diskExtent</type>
        <size>0</size>
        <accessible>true</accessible>
      </file>
      <file>
        <key>{{add .FileKeyBase 1}}</key>
        <name>[LocalDS_0] {{.VMName}}/disk{{.DiskNum}}.vmdk</name>
        <type>diskDescriptor</type>
        <size>0</size>
        <accessible>true</accessible>
      </file>
{{- end}}
{{- range .Disks}}
      <disk>
        <key>{{.Key}}</key>
        <chain>
          <fileKey>{{.FileKeyBase}}</fileKey>
          <fileKey>{{add .FileKeyBase 1}}</fileKey>
        </chain>
      </disk>
{{- end}}
      <timestamp>{{.Timestamp}}</timestamp>
    </val>
  </propSet>
  <propSet>
    <name>storage</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="VirtualMachineStorageInfo">
      <perDatastoreUsage>
        <datastore type="Datastore">datastore-39</datastore>
        <committed>0</committed>
        <uncommitted>{{.TotalBytes}}</uncommitted>
        <unshared>0</unshared>
      </perDatastoreUsage>
      <timestamp>{{.Timestamp}}</timestamp>
    </val>
  </propSet>
  <propSet>
    <name>environmentBrowser</name>
    <val type="EnvironmentBrowser" xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ManagedObjectReference">{{.EnvBrowser}}</val>
  </propSet>
  <propSet>
    <name>resourcePool</name>
    <val type="ResourcePool" xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ManagedObjectReference">{{.ResPoolID}}</val>
  </propSet>
  <propSet>
    <name>runtime</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="VirtualMachineRuntimeInfo">
      <host type="HostSystem">{{.HostID}}</host>
      <connectionState>connected</connectionState>
      <powerState>poweredOn</powerState>
      <faultToleranceState></faultToleranceState>
      <toolsInstallerMounted>false</toolsInstallerMounted>
      <numMksConnections>0</numMksConnections>
      <recordReplayState></recordReplayState>
      <onlineStandby>false</onlineStandby>
      <consolidationNeeded>false</consolidationNeeded>
    </val>
  </propSet>
  <propSet>
    <name>guest</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="GuestInfo">
      <toolsStatus>toolsNotInstalled</toolsStatus>
      <toolsRunningStatus>guestToolsNotRunning</toolsRunningStatus>
      <toolsVersion>0</toolsVersion>
      <guestFamily>linuxGuest</guestFamily>
      <net>
        <macAddress>{{.MACAddress}}</macAddress>
        <connected>true</connected>
        <deviceConfigId>4000</deviceConfigId>
      </net>
      <guestState></guestState>
    </val>
  </propSet>
  <propSet>
    <name>summary</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="VirtualMachineSummary">
      <vm type="VirtualMachine">vm-{{.VMID}}</vm>
      <runtime>
        <host type="HostSystem">{{.HostID}}</host>
        <connectionState>connected</connectionState>
        <powerState>poweredOn</powerState>
        <faultToleranceState></faultToleranceState>
        <toolsInstallerMounted>false</toolsInstallerMounted>
        <bootTime>{{.Timestamp}}</bootTime>
        <numMksConnections>0</numMksConnections>
        <recordReplayState></recordReplayState>
        <onlineStandby>false</onlineStandby>
        <consolidationNeeded>false</consolidationNeeded>
      </runtime>
      <guest>
        <guestId>otherGuest</guestId>
        <toolsStatus>toolsNotInstalled</toolsStatus>
      </guest>
      <config>
        <name>{{.Name}}</name>
        <template>false</template>
        <vmPathName>[LocalDS_0] {{.Name}}/{{.Name}}.vmx</vmPathName>
        <memorySizeMB>{{.MemoryMB}}</memorySizeMB>
        <numCpu>{{.NumCPU}}</numCpu>
        <numEthernetCards>1</numEthernetCards>
        <numVirtualDisks>{{.NumDisks}}</numVirtualDisks>
        <uuid>{{.UUID}}</uuid>
        <instanceUuid>{{.InstanceUUID}}</instanceUuid>
        <guestId>otherGuest</guestId>
        <guestFullName>otherGuest</guestFullName>
        <hwVersion>vmx-13</hwVersion>
      </config>
      <storage>
        <committed>0</committed>
        <uncommitted>{{.TotalBytes}}</uncommitted>
        <unshared>0</unshared>
        <timestamp>{{.Timestamp}}</timestamp>
      </storage>
      <quickStats>
        <guestHeartbeatStatus>gray</guestHeartbeatStatus>
      </quickStats>
      <overallStatus>green</overallStatus>
    </val>
  </propSet>
  <propSet>
    <name>datastore</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfManagedObjectReference">
      <ManagedObjectReference type="Datastore">datastore-39</ManagedObjectReference>
    </val>
  </propSet>
  <propSet>
    <name>network</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfManagedObjectReference">
      <ManagedObjectReference type="DistributedVirtualPortgroup">dvportgroup-12</ManagedObjectReference>
    </val>
  </propSet>
  <propSet>
    <name>rootSnapshot</name>
    <val xmlns:_XMLSchema-instance="http://www.w3.org/2001/XMLSchema-instance" _XMLSchema-instance:type="ArrayOfManagedObjectReference"></val>
  </propSet>
</ObjectContent>